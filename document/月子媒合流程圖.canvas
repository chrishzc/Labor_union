		{"id":"ae12b36ecd2684e1","type":"text","text":"💬 **[固定訊息] 滿意度調查 Google 表單**\n(需帶入訂單 ID 與 Mail給客戶)","x":640,"y":388,"width":280,"height":102,"color":"6"},
