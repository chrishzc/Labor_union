{
	"nodes":[
		{"id":"d58513af5f1be4da","type":"text","text":"未來流程","x":-440,"y":0,"width":1220,"height":60},
		{"id":"b6c43b70f323ae46","type":"text","text":"**客戶在政府網填表**\n(產生訂單ID)","x":-440,"y":100,"width":280,"height":80,"color":"1"},
		{"id":"9f68d2ac622ff54e","type":"text","text":"**電聯客戶**\n(確認細節)","x":-440,"y":210,"width":280,"height":80,"color":"3"},
		{"id":"5e984563416e613d","type":"text","text":"客戶動作","x":-650,"y":108,"width":120,"height":72,"color":"1"},
		{"id":"53570015aae2036f","type":"text","text":"人工動作","x":-650,"y":214,"width":120,"height":72,"color":"3"},
		{"id":"679f00c2c6b7dbda","type":"text","text":"自動","x":-650,"y":320,"width":120,"height":72,"color":"6"},
		{"id":"d6701f48cdb922db","type":"text","text":"**客戶加 LINE官方帳號**(標記訂單ID)\n傳送歡迎訊息請客戶填寫 BeClass 表單\n\n","x":-460,"y":313,"width":320,"height":88,"color":"1"},
		{"id":"1da45ca3368059c6","type":"text","text":"**[固定訊息]客戶7天後未填寫表單**\n超過7天處理案件時限，詢問是否取消訂單\n","x":-746,"y":561,"width":275,"height":98,"color":"6"},
		{"id":"3b4452269dce8504","type":"text","text":"**[固定訊息]每天詢問是否取消訂單**\n","x":-733,"y":692,"width":250,"height":96,"color":"6"},
		{"id":"52fd4fa43eddf57a","type":"text","text":"系統標記去銷訂單","x":-668,"y":813,"width":120,"height":72,"color":"6"},
		{"id":"8f91a1ef0e2f1202","type":"text","text":"**傳送服務人員資料**\n(PDF 履歷)","x":-441,"y":810,"width":280,"height":80,"color":"3"},
		{"id":"21ea3397cfafd960","type":"text","text":"💬 **[固定訊息] 提醒登記與契約**\n若三天內客戶沒有填寫表單，每天發送提醒訊息","x":-441,"y":428,"width":280,"height":80,"color":"6"},
		{"id":"909ec807ab8eac76","type":"text","text":"**詢問服務人員接案意願**\n","x":-411,"y":730,"width":222,"height":50,"color":"3"},
		{"id":"160258cb6c75f372","type":"text","text":"**[固定訊息]確認訂單資訊**","x":-418,"y":630,"width":236,"height":72,"color":"6"},
		{"id":"1e5a3bd1ab72dbd6","type":"text","text":"**客戶填寫beclass表單訂單成立**","x":-405,"y":540,"width":208,"height":70,"color":"6"},
		{"id":"db4f8acb93dcc2ef","type":"text","text":"🟢 **【確認服務開始時間前 3 天】**","x":520,"y":211,"width":280,"height":50,"color":"4"},
		{"id":"efd6f4b56c6a482e","type":"text","text":"💬 **[固定訊息] 確認寶寶狀況**\n","x":520,"y":291,"width":280,"height":80,"color":"6"},
		{"id":"cf3ee4e7e7170487","type":"text","text":"**討論餐食 **","x":520,"y":401,"width":280,"height":80,"color":"3"},
		{"id":"5991839c4a513916","type":"text","text":"🟢 **【服務期間】**\n(服務人員與雇主)","x":520,"y":521,"width":280,"height":70,"color":"4"},
		{"id":"4df449208c2a8850","type":"text","text":"💬 **[固定訊息] 提醒服務人員上傳寶寶日誌**","x":520,"y":636,"width":280,"height":80,"color":"6"},
		{"id":"2725739c4f7f3acb","type":"text","text":" **[固定訊息] 提醒客戶結清尾款給服務人員**","x":520,"y":761,"width":280,"height":80,"color":"6"},
		{"id":"ac67637cd52df4f6","type":"text","text":"**討論動線與時間**","x":520,"y":109,"width":280,"height":80,"color":"3"},
		{"id":"b5e2a54276a98b2a","type":"text","text":"🟢 **【結案前 5 天】**","x":960,"y":121,"width":280,"height":50,"color":"4"},
		{"id":"ae12b36ecd2684e1","type":"text","text":"💬 **[固定訊息] 滿意度調查 Google 表單**\n(需帶入訂單 ID 與 Mail給客戶)","x":960,"y":221,"width":280,"height":102,"color":"6"},
		{"id":"2942dceeaa29668e","type":"text","text":"💬 **[固定訊息] 推薦回饋邀請**","x":960,"y":361,"width":280,"height":80,"color":"6"},
