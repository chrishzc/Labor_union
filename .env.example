# 新竹市月子公會自動化系統 - 環境變數範本
# 請複製此檔案並命名為 .env，然後填入實際的金鑰與設定值

# LINE Messaging API 設定
LINE_CHANNEL_ID=your_line_channel_id_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_LOGIN_ID=your_line_login_id_here
LINE_LOGIN_SECRET=your_line_login_secret_here

# LINE LIFF 與系統對外網址設定
LINE_LIFF_ID=your_liff_id_here
BASE_URL=https://your-ngrok-domain.ngrok-free.app

# 資料庫連線配置 (供未來系統容器化或需要透過環境變數傳遞時使用)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1234
DB_DATABASE=union_db

# 好好簽 (BreezySign) API 設定
BREEZYSIGN_API_KEY=your_breezysign_api_key_here
BREEZYSIGN_API_URL=https://api.breezysign.com/v1
BREEZYSIGN_TEMPLATE_ID=your_breezysign_template_id_here

# BeClass API 設定
BECLASS_API_KEY=your_beclass_api_key_here
BECLASS_CLASS_ID=your_beclass_class_id_here
BECLASS_API_URL=https://www.beclass.com/api/get_registrations
